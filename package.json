{
  "name": "komm-hub",
  "version": "1.0.0",
  "description": "Komm hub frontend dependencies",
  "scripts": {
    "purge-icons": "purgecss --css node_modules/@mdi/font/css/materialdesignicons.css --content \"src/main/resources/templates/**/*.html\" --output src/main/resources/static/css/icons.css",
    "copy-fonts": "node -e \"require('fs').cpSync('node_modules/@mdi/font/fonts', 'src/main/resources/static/fonts', {recursive: true})\""
  },
  "dependencies": {
    "@mdi/font": "^7.4.47"
  },
  "devDependencies": {
    "purgecss": "^7.0.2"
  },
  "overrides": {
    "lru-cache": "11.2.4"
  }
}
