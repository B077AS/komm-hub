<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console Appender with Custom Color Converter -->
    <conversionRule conversionWord="customLevel" class="com.kommhub.config.CustomDebugConfig" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %customLevel(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling File Appender with GZ compression -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/komm.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rollover with .gz compression -->
            <fileNamePattern>logs/komm.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>

            <!-- Each file should be at most 10MB -->
            <maxFileSize>10MB</maxFileSize>

            <!-- Keep 30 days worth of history -->
            <maxHistory>30</maxHistory>

            <!-- Total size of all archive files -->
            <totalSizeCap>1GB</totalSizeCap>

            <!-- Delete archives older than 30 days -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- Package-specific Log Levels -->
    <logger name="com.kommhub" level="DEBUG" />
    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.springframework.security" level="INFO" />
    <logger name="org.h2" level="INFO" />
    <logger name="com.zaxxer.hikari" level="INFO" />

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>